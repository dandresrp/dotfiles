#!/usr/bin/env sh
set -eu

for dependency in git codex awk sed; do
  command -v "$dependency" >/dev/null 2>&1 || exit 1
done

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 1
cd "$repo_root" || exit 1

git diff --cached --quiet --exit-code && exit 1

tmpdir="${TMPDIR:-/tmp}"
diff_file="$(mktemp "$tmpdir/lazygit-codex-diff.XXXXXX")" || exit 1
response_file="$(mktemp "$tmpdir/lazygit-codex-response.XXXXXX")" || exit 1
log_file="$(mktemp "$tmpdir/lazygit-codex-log.XXXXXX")" || exit 1
cleanup() {
  rm -f "$diff_file" "$response_file" "$log_file"
}
trap cleanup EXIT HUP INT TERM

git diff --cached --no-ext-diff > "$diff_file" || exit 1

prompt='Generate exactly one Conventional Commit subject line for the staged git diff provided on stdin.
Rules:
- Output only the commit subject line.
- Use a lowercase type from: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert.
- Use format: type(optional-scope): short imperative summary.
- Keep it concise and preferably 72 characters or fewer.
- Use imperative mood.
- Do not output markdown, quotes, bullets, explanation, a body, or a trailing period.
- Do not mention file names unless they are essential to the summary.'

codex exec --ephemeral --sandbox read-only --color never -c 'model_reasoning_effort="low"' --output-last-message "$response_file" "$prompt" < "$diff_file" > "$log_file" 2>&1 || exit 1

message="$(awk 'NF { print; exit }' "$response_file" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//; s/^`+//; s/`+$//; s/^"+//; s/"+$//')"

[ -n "$message" ] || exit 1

printf '%s\n' "$message"
