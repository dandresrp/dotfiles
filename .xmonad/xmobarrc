Config { 

   -- appearance
     font = "xft:Source Code Pro:size=10:weight=bold:antialias=true:hinting=true"
   , additionalFonts = [ "xft:Ubuntu Mono:size=12:antialias=true:hinting=true"
                       , "xft:Font Awesome 5 Free Solid:size=12"
                       , "xft:Font Awesome 5 Brands:pixelsize=12"                    
                       ]
   , bgColor = "#282c34"
   , fgColor = "#ff6c6b"
   , position = TopSize L 100 25
   , border = BottomB
   , borderColor = "#646464"

   -- layout
   , sepChar =  "%"   -- delineator between plugin names and straight text
   , alignSep = "}{"  -- separator between left-right alignment
   , template = " <icon=haskell_20.xpm/> <fc=#666666>|</fc> %UnsafeStdinReader% }{ %date% "

   -- general behavior
   , lowerOnStart =     True    -- send to bottom of window stack on start
   , hideOnStart =      False   -- start with window unmapped (hidden)
   , allDesktops =      True    -- show on all desktops
   , overrideRedirect = True    -- set the Override Redirect flag (Xlib)
   , pickBroadest =     False   -- choose widest display (multi-monitor)
   , persistent =       True    -- enable/disable hiding (True = disabled)
   , iconRoot = ".xmonad/xpm/"  -- default: "."
   , commands = 

        -- weather monitor
        [ Run UnsafeStdinReader
        , Run Date           "<fn=1><fc=#FFFFFF>%I:%M %p - %d/%m/%Y </fc></fn>" "date" 10
        ]
   }
