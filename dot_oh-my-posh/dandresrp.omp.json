{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "upgrade": {
    "source": "cdn",
    "interval": "168h",
    "auto": false,
    "notice": false
  },
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#cba6f7",
    "template": "❯ "
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "folder_separator_icon": " \ue0b1 ",
            "home_icon": "~",
            "style": "folder"
          },
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b0",
          "template": " \uea83 {{ .Path }} ",
          "foreground": "#1e1e2e",
          "background": "#89b4fa",
          "type": "path",
          "style": "diamond"
        },
        {
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }} {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "foreground": "#1e1e2e",
          "powerline_symbol": "\ue0b0",
          "background": "#cba6f7",
          "type": "git",
          "style": "powerline",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#f9e2af{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#f38ba8{{ end }}",
            "{{ if gt .Ahead 0 }}#89dceb{{ end }}",
            "{{ if gt .Behind 0 }}#fab387{{ end }}"
          ]
        },
        {
          "options": {
            "always_enabled": true
          },
          "template": "<transparent>\ue0b0</> \ueba2 {{ .FormattedMs }}\u2800",
          "foreground": "#cdd6f4",
          "background": "#45475a",
          "type": "executiontime",
          "style": "plain"
        },
        {
          "options": {
            "always_enabled": true
          },
          "trailing_diamond": "\ue0b4",
          "template": "<parentBackground>\ue0b0</> \ue23a ",
          "foreground": "#1e1e2e",
          "background": "#a6e3a1",
          "type": "status",
          "style": "diamond",
          "background_templates": ["{{ if gt .Code 0 }}#f38ba8{{ end }}"]
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "template": "❯",
          "foreground": "#b4befe"
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "options": {
            "charged_icon": "\ue22f ",
            "charging_icon": "\ue234 ",
            "discharging_icon": "\ue231 "
          },
          "template": " {{ .Icon }}{{ .Percentage }}\uf295 ",
          "foreground": "#1e1e2e",
          "background": "#f5c2e7",
          "type": "battery",
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b0",
          "background_templates": [
            "{{if eq \"Charging\" .State.String}}#94e2d5{{end}}",
            "{{if eq \"Discharging\" .State.String}}#f9e2af{{end}}",
            "{{if eq \"Full\" .State.String}}#a6e3a1{{end}}"
          ]
        },
        {
          "trailing_diamond": "\ue0b4",
          "template": " {{ .CurrentDate | date .Format }}",
          "foreground": "#bac2de",
          "background": "#313244",
          "type": "time",
          "style": "diamond",
          "invert_powerline": true
        }
      ]
    }
  ],
  "version": 4,
  "final_space": true
}
