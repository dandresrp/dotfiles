HISTFILE=~/.histfile
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt APPEND_HISTORY
setopt SHARE_HISTORY

bindkey -v
export KEYTIMEOUT=1

zstyle :compinstall filename '/home/dandresrp/.zshrc'
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
    compinit
else
    compinit -C
fi

eval "$(~/.local/bin/mise activate zsh)"

if [[ ! -f $HOME/.local/share/zinit/zinit.git/zinit.zsh ]]; then
    print -P "%F{33} %F{220}Installing %F{33}ZDHARMA-CONTINUUM%F{220} Initiative Plugin Manager (%F{33}zdharma-continuum/zinit%F{220})…%f"
    command mkdir -p "$HOME/.local/share/zinit" && command chmod g-rwX "$HOME/.local/share/zinit"
    command git clone https://github.com/zdharma-continuum/zinit "$HOME/.local/share/zinit/zinit.git" && \
        print -P "%F{33} %F{34}Installation successful.%f%b" || \
        print -P "%F{160} The clone has failed.%f%b"
fi

source "$HOME/.local/share/zinit/zinit.git/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

zinit ice blockf
zinit light zsh-users/zsh-completions

zinit ice wait lucid
zinit light zsh-users/zsh-autosuggestions

# zinit ice wait lucid
# zinit light zsh-users/zsh-syntax-highlighting

zinit ice wait lucid
zinit light zdharma-continuum/fast-syntax-highlighting

zinit ice wait lucid
zinit light Aloxaf/fzf-tab

eval "$(oh-my-posh init zsh)"

if [[ -f /usr/share/fzf/shell/key-bindings.zsh ]]; then
    source /usr/share/fzf/shell/key-bindings.zsh
fi
if [[ -f /usr/share/fzf/shell/completion.zsh ]]; then
    source /usr/share/fzf/shell/completion.zsh
fi

export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border --preview "bat --color=always --style=plain --paging=never {}"'
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git 2>/dev/null || find . -type f -not -path "*/\.*"'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

if (( $+commands[eza] )); then
    alias ls='eza --group-directories-first'
    alias l='eza --group-directories-first'
    alias la='eza -a --group-directories-first'
    alias ll='eza -l --group-directories-first'
    alias lla='eza -la --group-directories-first'
    alias lt='eza -T --group-directories-first'
    alias lta='eza -Ta --group-directories-first'
    
    alias lg='eza -l --git --git-ignore --group-directories-first'
    alias lga='eza -la --git --group-directories-first'
    alias lsize='eza -l --sort=size --group-directories-first --reverse'
    alias lmod='eza -l --sort=modified --group-directories-first --reverse'
fi

if (( $+commands[bat] )); then
    alias cat='bat --style=plain --paging=never'
fi

if (( $+commands[git] )); then
    alias g='git'
    alias gs='git status'
    alias ga='git add'
    alias gc='git commit'
    alias gp='git push'
    alias gpl='git pull'
    alias gl='git log --oneline --graph --decorate'
    alias gd='git diff'
    alias gco='git checkout'
    alias gb='git branch'
fi

if (( $+commands[dnf] )); then
    alias dnfs='dnf search'
    alias dnfi='sudo dnf install'
    alias dnfu='sudo dnf upgrade'
    alias dnfr='sudo dnf remove'
    alias dnfh='dnf history'
    alias dnfl='dnf list installed'
fi

alias reload='source ~/.zshrc'
alias zshconfig='${EDITOR:-nano} ~/.zshrc'

alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

export EDITOR='nvim'
export VISUAL='nvim'
export PAGER='less'

export LESS_TERMCAP_mb=$'\E[1;31m'
export LESS_TERMCAP_md=$'\E[1;36m'
export LESS_TERMCAP_me=$'\E[0m'
export LESS_TERMCAP_se=$'\E[0m'
export LESS_TERMCAP_so=$'\E[01;44;33m'
export LESS_TERMCAP_ue=$'\E[0m'
export LESS_TERMCAP_us=$'\E[1;32m'

setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt PUSHD_SILENT

for index ({1..9}) alias "$index"="cd +${index}"; unset index

setopt AUTO_CD
setopt EXTENDED_GLOB
setopt NO_BEEP
setopt CORRECT

extract() {
    if [[ -f $1 ]]; then
        case $1 in
            *.tar.bz2)   tar xjf $1    ;;
            *.tar.gz)    tar xzf $1    ;;
            *.tar.xz)    tar xJf $1    ;;
            *.bz2)       bunzip2 $1    ;;
            *.rar)       unrar x $1    ;;
            *.gz)        gunzip $1     ;;
            *.tar)       tar xf $1     ;;
            *.tbz2)      tar xjf $1    ;;
            *.tgz)       tar xzf $1    ;;
            *.zip)       unzip $1      ;;
            *.Z)         uncompress $1 ;;
            *.7z)        7z x $1       ;;
            *)           echo "Can't extract '$1'..." ;;
        esac
    else
        echo "'$1' is not a valid file."
    fi
}

export PNPM_HOME="/home/dandresrp/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

if (( $+commands[zoxide] )); then
    eval "$(zoxide init zsh)"
fi

if (( $+commands[atuin] )); then
    eval "$(atuin init zsh)"
fi
